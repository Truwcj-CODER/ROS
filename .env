# ==========================================
# MODE: true = dev laptop | false = jetson
# ==========================================
DEV_MODE=false

# --- Dev (laptop) ---
DEV_IMAGE=linorobot2_humble:latest
DEV_VOLUME=/home/trucnv/Documents/robot_dev/linorobot2_ws
DEV_RUNTIME=runc

# --- Prod (Jetson) ---
JETSON_IMAGE=dustynv/ros:humble-desktop-l4t-r35.4.1
JETSON_VOLUME=/home/jetson/ROS
JETSON_RUNTIME=nvidia

# --- Shared ---
LINOROBOT2_BASE=2wd
LINOROBOT2_LASER_SENSOR=a2
